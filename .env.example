# Application
APP_NAME=async-task-service
LOG_LEVEL=INFO

# =============================================================================
# DEV-ONLY CREDENTIALS
# The credentials below are convenience defaults for LOCAL DEVELOPMENT ONLY.
# They MUST be overridden with strong, secret values in any shared or
# production environment (e.g. via a secrets manager or your orchestrator).
# Never commit real production secrets to this file.
# =============================================================================

# Database (asyncpg). Host "postgres" is the docker-compose service name.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/tasks

# RabbitMQ. Host "rabbitmq" is the docker-compose service name.
# Uses the explicit application account below (not the default "guest").
RABBITMQ_URL=amqp://app:app@rabbitmq:5672/

# Messaging / worker
TASK_QUEUE_NAME=tasks
WORKER_CONCURRENCY=4

# Postgres container bootstrap (consumed by the postgres image) — DEV-ONLY.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tasks

# RabbitMQ container bootstrap (consumed by the rabbitmq image) — DEV-ONLY.
# Must match the credentials embedded in RABBITMQ_URL above.
RABBITMQ_DEFAULT_USER=app
RABBITMQ_DEFAULT_PASS=app
